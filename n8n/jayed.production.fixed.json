                                         "jsCode":  "// รขลโฆ PREPROCESS INPUT (text / image / voice / postback)\nlet webhookJson = {};\ntry {\n  webhookJson = $(\u0027Webhook1\u0027).first().json;\n} catch (e1) {\n  try {\n    webhookJson = $(\u0027Webhook\u0027).first().json;\n  } catch (e2) {\n    webhookJson = {};\n  }\n}\n\nconst messaging = webhookJson?.body?.entry?.[0]?.messaging?.[0] || {};\n\nconst postbackRaw = messaging?.postback?.payload;\nconst textRaw = messaging?.message?.text;\n\n// Analyze image output fallback\nconst imageRaw =\n  $json?.content?.[0]?.text ??\n  $json?.[\u00270\u0027]?.content?.[0]?.text ??\n  \u0027\u0027;\n\n// Transcribe output fallback\nconst voiceRaw =\n  $json?.text ??\n  $json?.transcription ??\n  \u0027\u0027;\n\nconst isValid = (v) =\u003e\n  v !== undefined \u0026\u0026\n  v !== null \u0026\u0026\n  String(v).trim() !== \u0027\u0027 \u0026\u0026\n  String(v).trim().toLowerCase() !== \u0027undefined\u0027 \u0026\u0026\n  String(v).trim().toLowerCase() !== \u0027null\u0027;\n\nlet inputType = \u0027UNKNOWN\u0027;\nlet inputValue = \u0027\u0027;\n\nif (isValid(postbackRaw)) {\n  inputType = \u0027POSTBACK\u0027;\n  inputValue = String(postbackRaw).trim();\n} else if (isValid(imageRaw)) {\n  inputType = \u0027IMAGE\u0027;\n  inputValue = String(imageRaw).trim();\n} else if (isValid(voiceRaw)) {\n  inputType = \u0027VOICE\u0027;\n  inputValue = String(voiceRaw).trim();\n} else if (isValid(textRaw)) {\n  inputType = \u0027TEXT\u0027;\n  inputValue = String(textRaw).trim();\n}\n\nconst sender = messaging?.sender?.id || \u0027\u0027;\n\nreturn [{ json: { inputType, inputValue, sender } }];"
                                     },
